# Copy this file to .env and fill in your values

# Supabase Transaction Pooler (used at runtime by Prisma)
DATABASE_URL="postgresql://postgres.YOURREF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Supabase Direct Connection (used for migrations only)
DIRECT_URL="postgresql://postgres.YOURREF:PASSWORD@db.YOURREF.supabase.co:5432/postgres"
